{
  "providers": {
    "openrouter": {
      "apiKey": "${OPENROUTER_API_KEY}"
    }
  },
  "agents": {
    "defaults": {
      "provider": "openrouter",
      "model": "anthropic/claude-opus-4-6",
      "maxTokens": 8192,
      "contextWindowTokens": 65536,
      "timezone": "Asia/Shanghai"
    }
  },
  "channels": {
    "telegram": {
      "enabled": true,
      "token": "${TELEGRAM_BOT_TOKEN}",
      "allowFrom": ["YOUR_USER_ID"],
      "streaming": true
    }
  },
  "tools": {
    "web": {
      "enable": true,
      "search": {
        "provider": "duckduckgo",
        "maxResults": 5
      },
      "fetch": {
        "timeout": 30,
        "maxContentSize": 100000
      }
    },
    "exec": {
      "enable": true,
      "sandbox": "none",
      "timeout": 60
    }
  },
  "cron": {
    "enabled": true,
    "tasks": [
      {
        "name": "hourly_price_check",
        "schedule": "0 * * * *",
        "command": "/check_prices BTC ETH SOL"
      },
      {
        "name": "daily_market_report",
        "schedule": "0 9 * * 1-5",
        "command": "/generate_daily_report"
      },
      {
        "name": "weekly_summary",
        "schedule": "0 18 * * 5",
        "command": "/generate_weekly_summary"
      }
    ]
  }
}
